# --- LLM Configuration ---
# Add your OpenAI key below for live LLM synthesis.
# Without a valid key the system runs in graph+vector-only demo mode.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set API_KEY to a secret string to enable API key auth. Leave empty to disable auth (for local dev/demo).
API_KEY=

FRONTEND_URL=http://localhost:3000
QDRANT_HOST=qdrant
QDRANT_PORT=6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_THIS_BEFORE_PRODUCTION
REDIS_URL=redis://redis:6379
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=gpt-4o
APP_ENV=development
LOG_LEVEL=INFO
